# DS4 virtual USB descriptor profile.
# Exposes USB Audio output plus DS4-compatible HID. The map owns all
# USB-to-Bluetooth report translation.

[profile]
id = ds4_composite
name = Wireless Controller-E USB Audio/HID
status = experimental_audio_hid

[device_descriptor]
# Mirrors the real wired DS4 baseline: VID 054c, PID 09cc.
# iSerialNumber remains 3 so CMU can stamp the physical BT serial.
bytes = 0x12 0x01 0x00 0x02 0x00 0x00 0x00 0x40 0x4C 0x05 0xCC 0x09 0x00 0x01 0x01 0x02 0x03 0x01

[configuration_descriptor]
# Mirrors the real wired DS4 layout:
# Interface 0: Audio Control.
# Interface 1: 32 kHz stereo speaker ISO OUT 0x01.
# Interface 2: 16 kHz mono microphone ISO IN 0x82.
# Interface 3: HID, interrupt IN 0x84 and OUT 0x03.
#
# bInterval on the ISO endpoints is set to 0x04 (HS-correct 1 ms service
# interval -- usbip-win2 exposes us as high-speed). The real wired DS4 uses
# bInterval=0x01, but that captures the FS interpretation; at HS that becomes
# 125 us, which the kernel HD-audio path will not schedule. DS5 uses the same
# 0x04 here and works. See docs/ds4_knowledge.md for the wireshark capture.
bytes = 0x09 0x02 0xE1 0x00 0x04 0x01 0x00 0xC0 0xFA 0x09 0x04 0x00 0x00 0x00 0x01 0x01 0x00 0x00 0x0A 0x24 0x01 0x00 0x01 0x47 0x00 0x02 0x01 0x02 0x0C 0x24 0x02 0x01 0x01 0x01 0x06 0x02 0x03 0x00 0x00 0x00 0x0A 0x24 0x06 0x02 0x01 0x01 0x03 0x00 0x00 0x00 0x09 0x24 0x03 0x03 0x02 0x04 0x04 0x02 0x00 0x0C 0x24 0x02 0x04 0x02 0x04 0x03 0x01 0x00 0x00 0x00 0x00 0x09 0x24 0x06 0x05 0x04 0x01 0x03 0x00 0x00 0x09 0x24 0x03 0x06 0x01 0x01 0x01 0x05 0x00 0x09 0x04 0x01 0x00 0x00 0x01 0x02 0x00 0x00 0x09 0x04 0x01 0x01 0x01 0x01 0x02 0x00 0x00 0x07 0x24 0x01 0x01 0x01 0x01 0x00 0x0B 0x24 0x02 0x01 0x02 0x02 0x10 0x01 0x00 0x7D 0x00 0x09 0x05 0x01 0x09 0x84 0x00 0x04 0x00 0x00 0x07 0x25 0x01 0x00 0x00 0x00 0x00 0x09 0x04 0x02 0x00 0x00 0x01 0x02 0x00 0x00 0x09 0x04 0x02 0x01 0x01 0x01 0x02 0x00 0x00 0x07 0x24 0x01 0x06 0x01 0x01 0x00 0x0B 0x24 0x02 0x01 0x01 0x02 0x10 0x01 0x80 0x3E 0x00 0x09 0x05 0x82 0x05 0x22 0x00 0x04 0x00 0x00 0x07 0x25 0x01 0x00 0x00 0x00 0x00 0x09 0x04 0x03 0x00 0x02 0x03 0x00 0x00 0x00 0x09 0x21 0x11 0x01 0x00 0x01 0x22 0xFB 0x01 0x07 0x05 0x84 0x03 0x40 0x00 0x05 0x07 0x05 0x03 0x03 0x40 0x00 0x05

