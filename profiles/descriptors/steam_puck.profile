# Steam Controller via Valve "Steam Puck" receiver (VID 0x28DE, PID 0x1304).
# Captured from a live wired puck on a webOS TV via the cmu_hidraw_bridge
# --enumerate command. One Steam Controller slot exposed as a single HID
# interface; the puck composite has four identical slots + a management
# interface (54-byte descriptor). v1 exposes one slot at a time. Multi-slot
# composite is future work.

[profile]
id = steam_puck
name = Valve Steam Controller (via puck)
status = experimental_pass_through

[device_descriptor]
# 18-byte USB 2.0 device descriptor:
# bLength=0x12, bDescriptorType=0x01 (DEVICE), bcdUSB=0x0200,
# bDeviceClass=0x00 (per-interface), bMaxPacketSize0=0x40,
# idVendor=0x28DE, idProduct=0x1304, bcdDevice=0x0100,
# iManufacturer=1, iProduct=2, iSerial=3, bNumConfigurations=1.
bytes = 0x12 0x01 0x00 0x02 0x00 0x00 0x00 0x40 0xDE 0x28 0x04 0x13 0x00 0x01 0x01 0x02 0x03 0x01

[configuration_descriptor]
# 41-byte single-interface config: HID class on interface 0,
# two interrupt endpoints (0x81 IN, 0x01 OUT, 64 B max, interval 8 ms).
# HID descriptor reports report-descriptor length = 0x0174 = 372.
# 9 (config) + 9 (interface) + 9 (HID) + 7 (ep IN) + 7 (ep OUT) = 41.
bytes = 0x09 0x02 0x29 0x00 0x01 0x01 0x00 0xA0 0xFA 0x09 0x04 0x00 0x00 0x02 0x03 0x00 0x00 0x00 0x09 0x21 0x11 0x01 0x00 0x01 0x22 0x74 0x01 0x07 0x05 0x81 0x03 0x40 0x00 0x08 0x07 0x05 0x01 0x03 0x40 0x00 0x08

[hid_report_descriptor]
# 372-byte Valve Steam Controller report descriptor (captured verbatim
# from /dev/hidraw0 of a real puck via HIDIOCGRDESC). Defines:
#   Mouse collection         report ID 0x40 (trackpad emulation)
#   Keyboard collection      report ID 0x41
#   Vendor input reports     report IDs 0x42, 0x44, 0x79, 0x43, 0x7B, 0x45,
#                                       0x80..0x89   (Steam native protocol)
#   Vendor feature reports   report IDs 0x01, 0x02
bytes = 0x05 0x01 0x09 0x02 0xA1 0x01 0x85 0x40 0x09 0x01 0xA1 0x00 0x05 0x09 0x19 0x01 0x29 0x02 0x15 0x00 0x25 0x01 0x75 0x01 0x95 0x02 0x81 0x02 0x75 0x06 0x95 0x01 0x81 0x01 0x05 0x01 0x09 0x30 0x09 0x31 0x15 0x81 0x25 0x7F 0x75 0x08 0x95 0x02 0x81 0x06 0x95 0x01 0x09 0x38 0x81 0x06 0x05 0x0C 0x0A 0x38 0x02 0x95 0x01 0x81 0x06 0xC0 0xC0 0x05 0x01 0x09 0x06 0xA1 0x01 0x85 0x41 0x05 0x07 0x19 0xE0 0x29 0xE7 0x15 0x00 0x25 0x01 0x75 0x01 0x95 0x08 0x81 0x02 0x81 0x01 0x19 0x00 0x29 0x65 0x15 0x00 0x25 0x65 0x75 0x08 0x95 0x06 0x81 0x00 0xC0 0x06 0x00 0xFF 0x09 0x01 0xA1 0x01 0x85 0x42 0x15 0x00 0x26 0xFF 0x00 0x75 0x08 0x95 0x35 0x09 0x42 0x81 0x02 0x85 0x44 0x15 0x00 0x26 0xFF 0x00 0x75 0x08 0x95 0x05 0x09 0x44 0x81 0x02 0x85 0x79 0x15 0x00 0x26 0xFF 0x00 0x75 0x08 0x95 0x01 0x09 0x79 0x81 0x02 0x85 0x43 0x15 0x00 0x26 0xFF 0x00 0x75 0x08 0x95 0x0E 0x09 0x43 0x81 0x02 0x85 0x7B 0x15 0x00 0x26 0xFF 0x00 0x75 0x08 0x95 0x0C 0x09 0x7B 0x81 0x02 0x85 0x45 0x15 0x00 0x26 0xFF 0x00 0x75 0x08 0x95 0x2D 0x09 0x45 0x81 0x02 0x85 0x80 0x15 0x00 0x26 0xFF 0x00 0x75 0x08 0x95 0x09 0x09 0x80 0x91 0x02 0x85 0x81 0x15 0x00 0x26 0xFF 0x00 0x75 0x08 0x95 0x07 0x09 0x81 0x91 0x02 0x85 0x82 0x15 0x00 0x26 0xFF 0x00 0x75 0x08 0x95 0x03 0x09 0x82 0x91 0x02 0x85 0x83 0x15 0x00 0x26 0xFF 0x00 0x75 0x08 0x95 0x09 0x09 0x83 0x91 0x02 0x85 0x84 0x15 0x00 0x26 0xFF 0x00 0x75 0x08 0x95 0x08 0x09 0x84 0x91 0x02 0x85 0x85 0x15 0x00 0x26 0xFF 0x00 0x75 0x08 0x95 0x03 0x09 0x85 0x91 0x02 0x85 0x86 0x15 0x00 0x26 0xFF 0x00 0x75 0x08 0x95 0x03 0x09 0x86 0x91 0x02 0x85 0x87 0x15 0x00 0x26 0xFF 0x00 0x75 0x08 0x95 0x3F 0x09 0x87 0x91 0x02 0x85 0x89 0x15 0x00 0x26 0xFF 0x00 0x75 0x08 0x95 0x3F 0x09 0x89 0x91 0x02 0x85 0x88 0x15 0x00 0x26 0xFF 0x00 0x75 0x08 0x95 0x3F 0x09 0x88 0x91 0x02 0x85 0x01 0x95 0x3F 0x09 0x01 0xB1 0x02 0x85 0x02 0x95 0x3F 0x09 0x01 0xB1 0x02 0xC0

[string_descriptors]
# LangID (0x0409 = en-US), then "Valve Software" (manufacturer, idx 1),
# "Steam Controller" (product, idx 2), empty placeholder (serial, idx 3 --
# the runtime stamps the bridge's real serial here at attach time).
bytes = 0x04 0x03 0x09 0x04 0x1E 0x03 0x56 0x00 0x61 0x00 0x6C 0x00 0x76 0x00 0x65 0x00 0x20 0x00 0x53 0x00 0x6F 0x00 0x66 0x00 0x74 0x00 0x77 0x00 0x61 0x00 0x72 0x00 0x65 0x00 0x22 0x03 0x53 0x00 0x74 0x00 0x65 0x00 0x61 0x00 0x6D 0x00 0x20 0x00 0x43 0x00 0x6F 0x00 0x6E 0x00 0x74 0x00 0x72 0x00 0x6F 0x00 0x6C 0x00 0x6C 0x00 0x65 0x00 0x72 0x00 0x02 0x03
