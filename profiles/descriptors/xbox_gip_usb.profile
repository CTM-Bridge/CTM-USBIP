# Real Xbox Series USB/GIP profile.
# Captured baseline: Microsoft VID/PID 045E:0B12, vendor class FF/47/D0,
# interrupt data endpoints 0x02 OUT and 0x82 IN, plus audio/bulk alternates.

[profile]
id = xbox_gip_usb
name = Xbox Wireless Controller
status = experimental_gip_usb

[device_descriptor]
# USB 2.0 full-speed device descriptor from the wired Xbox baseline.
bytes = 0x12 0x01 0x00 0x02 0xFF 0x47 0xD0 0x40 0x5E 0x04 0x12 0x0B 0x17 0x05 0x01 0x02 0x03 0x01

